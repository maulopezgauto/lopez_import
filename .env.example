# Configuración de AZUL - Plataforma de Pagos Dominicana
# Obtén estas credenciales afiliándote en https://portal.azul.com.do/

# Credenciales de AZUL
VITE_AZUL_AUTH1=AZUL
VITE_AZUL_AUTH2=AZUL
VITE_AZUL_MERCHANT_ID=3900000000
VITE_AZUL_CHANNEL=EC

# Ambiente de AZUL (true para producción, false para pruebas)
VITE_AZUL_PRODUCTION=false

# Clave de autenticación para hash (se obtiene de AZUL)
VITE_AZUL_AUTH_KEY=your_auth_key_here

# URL base del backend para peticiones (evita CORS al llamar AZUL)
# ej. http://localhost:4000
VITE_API_URL=http://localhost:4000

# Configuración de Stripe (si se mantiene como opción alternativa)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_key_here